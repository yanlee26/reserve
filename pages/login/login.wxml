<!--pages/login/login.wxml-->
<view class="container page-login animate-fade-in">
  <view class="login-card card glass">
    <!-- 医院品牌展示 -->
    <view class="hospital-brand">
      <view class="logo-box">🏩</view>
      <view class="name-zh">上海市浦东新区中医医院</view>
      <view class="sub-name">少儿推拿预约中心</view>
    </view>

    <!-- 角色选择切换 -->
    <view class="role-switch-container">
      <view class="role-tab {{role === 'parent' ? 'active' : ''}}" bindtap="onChangeRole" data-role="parent">我是家长</view>
      <view class="role-tab {{role === 'doctor' ? 'active' : ''}}" bindtap="onChangeRole" data-role="doctor">我是医生</view>
    </view>

    <!-- 说明须知 (仅对家长展示) -->
    <view class="notice-box" wx:if="{{role === 'parent'}}">
      <text class="notice-title">⚠️ 就诊预约前须知</text>
      <text class="notice-text">根据本院儿童保健科规定：只有经过医生线下诊断，持有医生诊断/处方单的患儿，方能进入系统预约推拿疗程。</text>
    </view>

    <!-- 说明须知 (仅对医生展示) -->
    <view class="notice-box notice-doctor" wx:if="{{role === 'doctor'}}">
      <text class="notice-title">👨‍⚕️ 医生工作站须知</text>
      <text class="notice-text">请输入您的验证工号进行登录。医生端仅支持查询各时段患者明细，不支持创建、修改或取消预约操作。</text>
    </view>

    <!-- 表单输入区域 -->
    <view class="form-area">
      <!-- 家长输入框 -->
      <view class="input-item" wx:if="{{role === 'parent'}}">
        <text class="label">医生诊断单号</text>
        <input 
          class="login-input" 
          placeholder="请输入就诊单上的诊断单号" 
          value="{{codeValue}}" 
          bindinput="onInputCode"
          placeholder-class="placeholder"
        />
        <text class="test-tip">（测试可用单号: TCM-999）</text>
      </view>

      <!-- 医生输入框 -->
      <view class="input-item" wx:if="{{role === 'doctor'}}">
        <text class="label">医生验证工号</text>
        <input 
          class="login-input" 
          placeholder="请输入您的医生工号" 
          value="{{codeValue}}" 
          bindinput="onInputCode"
          placeholder-class="placeholder"
        />
        <text class="test-tip">（测试可用工号: DOC-888）</text>
      </view>

      <!-- 手机号码输入框 -->
      <view class="input-item" style="margin-top: 30rpx;" wx:if="{{enableSmsLogin}}">
        <text class="label">绑定手机号码</text>
        <input 
          class="login-input" 
          type="number"
          maxlength="11"
          placeholder="请输入您的手机号码" 
          value="{{phone}}" 
          bindinput="onInputPhone"
          placeholder-class="placeholder"
        />
      </view>

      <!-- 验证码输入框 -->
      <view class="input-item" style="margin-top: 30rpx;" wx:if="{{enableSmsLogin}}">
        <text class="label">短信验证码</text>
        <view class="verify-code-row">
          <input 
            class="login-input verify-input" 
            type="number"
            maxlength="6"
            placeholder="请输入验证码" 
            value="{{verifyCode}}" 
            bindinput="onInputVerifyCode"
            placeholder-class="placeholder"
          />
          <button 
            class="send-code-btn {{isPhoneValid && countdown === 0 ? '' : 'disabled'}}" 
            disabled="{{!isPhoneValid || countdown > 0}}"
            bindtap="onSendVerifyCode"
          >
            {{countdown > 0 ? countdown + 's' : '获取验证码'}}
          </button>
        </view>
      </view>
    </view>

    <!-- 用户服务协议与隐私条款同意框 -->
    <view class="agreement-row flex items-center">
      <checkbox-group bindchange="onAgreementChange">
        <checkbox class="agreement-checkbox" value="agree" checked="{{isAgreed}}" color="#0d9488" />
      </checkbox-group>
      <text class="agreement-text">
        我已阅读并同意
        <text class="agreement-link" catchtap="viewServiceAgreement">《用户服务协议》</text>
        与
        <text class="agreement-link" catchtap="viewPrivacyPolicy">《隐私政策》</text>
      </text>
    </view>

    <!-- 登录按钮 -->
    <view class="action-area">
      <button 
        class="btn btn-primary login-btn {{isFormValid ? '' : 'btn-disabled'}}" 
        bindtap="onWechatLogin"
        disabled="{{!isFormValid}}"
      >
        微信授权登录
      </button>
    </view>
  </view>

  <!-- 用户协议/隐私条款详情弹窗 -->
  <view class="policy-modal-mask flex items-center justify-center animate-fade-in" wx:if="{{showPolicyModal}}" bindtap="closePolicyModal">
    <view class="policy-modal card glass animate-scale-up" catchtap="onModalInnerClick">
      
      <view class="modal-header flex justify-between items-center">
        <text class="modal-title">{{policyTitle}}</text>
        <text class="modal-close" bindtap="closePolicyModal">✕</text>
      </view>

      <scroll-view class="policy-body" scroll-y>
        <text class="policy-content" user-select>{{policyContent}}</text>
      </scroll-view>

      <view class="modal-footer">
        <button class="btn btn-primary agree-modal-btn" bindtap="agreeAndClosePolicy">已阅读并同意本协议</button>
      </view>

    </view>
  </view>
</view>
