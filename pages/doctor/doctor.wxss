/* pages/doctor/doctor.wxss */

.page-doctor {
  padding: 28rpx 28rpx 60rpx 28rpx;
  background-color: var(--bg-main);
  min-height: 100vh;
  box-sizing: border-box;
}

/* 顶部医生管理卡 */
.header-card {
  margin: 0 0 28rpx 0;
  padding: 30rpx 36rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(204, 251, 241, 0.3) 100%);
  border: 2rpx solid rgba(13, 148, 136, 0.1);
}

.hosp-name {
  font-size: 24rpx;
  color: var(--text-muted);
  font-weight: 500;
}

.dept-name {
  font-size: 36rpx;
  font-weight: 800;
  margin-top: 6rpx;
  display: inline-block;
}

.doctor-info {
  font-size: 22rpx;
  color: var(--text-muted);
  font-weight: 600;
  margin-top: 8rpx;
}

.logout-btn-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
  background-color: rgba(239, 68, 68, 0.08);
  border: 2rpx solid rgba(239, 68, 68, 0.1);
  transition: background-color 0.2s;
}

.logout-btn-box:active {
  background-color: rgba(239, 68, 68, 0.15);
}

.logout-icon {
  font-size: 32rpx;
  line-height: 1;
}

.logout-text {
  font-size: 20rpx;
  color: #ef4444;
  font-weight: 700;
  margin-top: 4rpx;
}

/* 15天日期横滑选择器 */
.calendar-section {
  padding: 32rpx 24rpx;
  margin-bottom: 28rpx;
}

.active-date-desc {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--primary);
  background-color: var(--primary-light);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
}

.date-scroll {
  white-space: nowrap;
  width: 100%;
}

.date-pill {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 110rpx;
  height: 130rpx;
  margin-right: 16rpx;
  border-radius: var(--radius-md);
  background-color: var(--bg-main);
  border: 2rpx solid var(--border-color);
  box-sizing: border-box;
  transition: all 0.2s;
}

.date-pill.active {
  background-color: var(--primary-light);
  border-color: var(--primary);
  color: var(--primary);
  box-shadow: 0 6rpx 16rpx rgba(13, 148, 136, 0.15);
  transform: translateY(-2rpx);
}

.day-name {
  font-size: 20rpx;
  color: var(--text-light);
  margin-bottom: 8rpx;
  font-weight: 500;
}

.date-pill.active .day-name {
  color: var(--primary);
  font-weight: 700;
}

.date-num {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-main);
}

.date-pill.active .date-num {
  color: var(--primary);
}

.summary-bar {
  display: flex;
  align-items: center;
  margin: 12rpx 8rpx 28rpx 8rpx;
}

.summary-text {
  font-size: 24rpx;
  color: var(--text-sub);
  font-weight: 600;
  display: flex;
  align-items: center;
}

.summary-text::before {
  content: '';
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  background-color: var(--primary);
  border-radius: 50%;
  margin-right: 12rpx;
  box-shadow: 0 0 8rpx var(--primary);
}

.summary-text .highlight {
  color: var(--primary);
  font-size: 30rpx;
  font-weight: 800;
  margin: 0 6rpx;
}

/* 简化三色网格 */
.grid-section {
  padding: 32rpx 24rpx;
}

.time-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.grid-pill {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 110rpx;
  border-radius: var(--radius-md);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.grid-pill:active {
  transform: scale(0.96);
}

.grid-pill.empty {
  background-color: #f0fdf4;
  border: 2rpx dashed #bbf7d0;
}

.grid-pill.empty .grid-time {
  color: #16a34a;
  font-weight: 700;
  font-size: 26rpx;
}

.grid-pill.empty .grid-state-label {
  color: #22c55e;
  font-size: 20rpx;
  margin-top: 4rpx;
}

/* 黄色: 已约 (待服务) */
.grid-pill.pending {
  background-color: #fffbeb;
  border-color: #fde68a;
  box-shadow: 0 4rpx 10rpx rgba(217, 119, 6, 0.05);
}

.grid-pill.pending .grid-time {
  color: #d97706;
  font-weight: 700;
  font-size: 26rpx;
}

.grid-pill.pending .grid-state-label {
  color: #f59e0b;
  font-size: 20rpx;
  font-weight: 700;
  margin-top: 4rpx;
}

/* 红色: 已取消 */
.grid-pill.cancelled {
  background-color: #fef2f2;
  border-color: #fecaca;
}

.grid-pill.cancelled .grid-time {
  color: #dc2626;
  font-weight: 700;
  font-size: 26rpx;
  text-decoration: line-through;
}

.grid-pill.cancelled .grid-state-label {
  color: #ef4444;
  font-size: 20rpx;
  font-weight: 700;
  margin-top: 4rpx;
}

/* 详情弹窗 (Modal) */
.detail-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  backdrop-filter: blur(10rpx);
}

.detail-modal {
  width: 85%;
  max-width: 600rpx;
  background-color: #ffffff;
  padding: 0rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 50rpx rgba(0, 0, 0, 0.15);
}

.modal-header {
  padding: 30rpx 36rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.modal-title {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-main);
}

.modal-close {
  font-size: 36rpx;
  color: var(--text-muted);
  padding: 10rpx;
}

.modal-body {
  padding: 36rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.modal-status-row {
  margin-bottom: 8rpx;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.dot-pending {
  background-color: #fbbf24;
}

.dot-cancelled {
  background-color: #ef4444;
}

.text-pending {
  color: #d97706;
  font-weight: 700;
  font-size: 26rpx;
}

.text-cancelled {
  color: #ef4444;
  font-weight: 700;
  font-size: 26rpx;
}

.modal-info-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  background-color: var(--bg-main);
  padding: 24rpx 28rpx;
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-color);
}

.modal-info-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
}

.modal-info-label {
  color: var(--text-muted);
  width: 140rpx;
  flex-shrink: 0;
}

.modal-info-val {
  color: var(--text-main);
  font-weight: 500;
}

.code-font {
  font-family: monospace, Courier, sans-serif;
  font-weight: 700;
}

.phone-call-item {
  cursor: pointer;
}

.phone-call-item:active {
  opacity: 0.7;
}

.phone-val {
  color: var(--primary);
  font-weight: 700;
  text-decoration: underline;
}

/* 取消原因警告框 */
.cancel-reason-box {
  padding: 18rpx 24rpx;
  background-color: #fef2f2;
  border-left: 6rpx solid #ef4444;
  border-radius: 0 8rpx 8rpx 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.reason-title {
  font-size: 22rpx;
  font-weight: 700;
  color: #991b1b;
}

.reason-content {
  font-size: 24rpx;
  color: #b91c1c;
  line-height: 1.5;
}

.modal-footer {
  padding: 24rpx 36rpx;
  border-top: 2rpx solid var(--border-color);
  background-color: var(--bg-main);
}

.close-modal-btn {
  height: 80rpx;
  line-height: 80rpx;
  border-radius: var(--radius-full);
  font-size: 26rpx;
  font-weight: 700;
}

/* 加载动画 */
.loading-box {
  padding: 100rpx 40rpx;
}

.spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid var(--border-color);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  color: var(--text-light);
}
