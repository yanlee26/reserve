<!--pages/doctor/doctor.wxml-->
<view class="container page-doctor animate-fade-in">
  
  <!-- 顶部医生品牌与管理卡 -->
  <view class="header-card card glass flex justify-between items-center">
    <view class="brand-info">
      <view class="hosp-name">上海市浦东新区中医医院</view>
      <view class="dept-name gradient-text">少儿推拿中心・医生端</view>
      <view class="doctor-info" wx:if="{{doctorId}}">工号: {{doctorId}}</view>
    </view>
    <view class="logout-btn-box" bindtap="onLogout">
      <text class="logout-icon">🚪</text>
      <text class="logout-text">退出</text>
    </view>
  </view>

  <!-- 15天日期选择器 -->
  <view class="calendar-section card">
    <view class="section-title-row" style="margin-bottom: 24rpx; justify-content: space-between; display: flex; align-items: center;">
      <text class="section-title">查看日期预约</text>
      <text class="active-date-desc" wx:if="{{selectedDateStr}}">{{selectedDateStr}}</text>
    </view>
    
    <scroll-view class="date-scroll" scroll-x scroll-with-animation scroll-into-view="date-{{selectedDateShort}}">
      <view 
        wx:for="{{dateList}}" 
        wx:key="date" 
        id="date-{{item.dateShort}}"
        class="date-pill {{selectedDate === item.date ? 'active' : ''}}"
        bindtap="onSelectDate"
        data-date="{{item.date}}"
        data-short="{{item.dateShort}}"
        data-str="{{item.dateStr}}"
      >
        <text class="day-name">{{item.dayName}}</text>
        <text class="date-num">{{item.dateShort}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 预约数量摘要 -->
  <view class="summary-bar" wx:if="{{!loading}}">
    <text class="summary-text">本日共有 <text class="highlight">{{bookings.length}}</text> 个预约记录</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading-box flex flex-col items-center justify-center" wx:if="{{loading}}">
    <view class="spinner"></view>
    <text class="loading-text">正在加载预约数据...</text>
  </view>

  <!-- 时间段日程网格 (简化三色网格) -->
  <view class="booking-grid-container" wx:else>
    
    <!-- 上午时段 -->
    <view class="grid-section card">
      <view class="section-title-row" style="margin-bottom: 24rpx;">
        <text class="section-title">🌅 上午时段 (08:00 - 12:00)</text>
      </view>
      <view class="time-grid">
        <view 
          class="grid-pill {{item.state}}" 
          wx:for="{{morningSlots}}" 
          wx:key="time"
          bindtap="onSlotClick"
          data-slot="{{item}}"
        >
          <text class="grid-time">{{item.time}}</text>
          <text class="grid-state-label">{{item.state === 'empty' ? '空闲' : (item.state === 'pending' ? '已约' : '取消')}}</text>
        </view>
      </view>
    </view>

    <!-- 下午时段 -->
    <view class="grid-section card" style="margin-top: 28rpx;">
      <view class="section-title-row" style="margin-bottom: 24rpx;">
        <text class="section-title">🌇 下午时段 (13:00 - 17:00)</text>
      </view>
      <view class="time-grid">
        <view 
          class="grid-pill {{item.state}}" 
          wx:for="{{afternoonSlots}}" 
          wx:key="time"
          bindtap="onSlotClick"
          data-slot="{{item}}"
        >
          <text class="grid-time">{{item.time}}</text>
          <text class="grid-state-label">{{item.state === 'empty' ? '空闲' : (item.state === 'pending' ? '已约' : '取消')}}</text>
        </view>
      </view>
    </view>

  </view>

  <!-- 预约详情弹窗 (Modal) -->
  <view class="detail-modal-mask flex items-center justify-center animate-fade-in" wx:if="{{showDetailModal}}" bindtap="closeDetailModal">
    <view class="detail-modal card glass animate-scale-up" catchtap="onModalInnerClick">
      
      <view class="modal-header flex justify-between items-center">
        <text class="modal-title">⏰ 预约详情 ({{activeBooking.time}})</text>
        <text class="modal-close" bindtap="closeDetailModal">✕</text>
      </view>

      <view class="modal-body">
        <!-- 状态标签 -->
        <view class="modal-status-row flex items-center">
          <text class="status-dot {{activeBooking.status === 'pending' ? 'dot-pending' : 'dot-cancelled'}}"></text>
          <text class="status-name {{activeBooking.status === 'pending' ? 'text-pending' : 'text-cancelled'}}">
            {{activeBooking.status === 'pending' ? '待服务 (已预约)' : '已取消'}}
          </text>
        </view>

        <!-- 信息明细 -->
        <view class="modal-info-grid">
          <view class="modal-info-item">
            <text class="modal-info-label">患儿姓名：</text>
            <text class="modal-info-val font-bold">{{activeBooking.patientName}}</text>
          </view>
          
          <view class="modal-info-item">
            <text class="modal-info-label">就诊单号：</text>
            <text class="modal-info-val code-font">{{activeBooking.diagnosisId}}</text>
          </view>

          <view class="modal-info-item phone-call-item" bindtap="onCallPatient" data-phone="{{activeBooking.patientPhone}}" data-name="{{activeBooking.patientName}}">
            <text class="modal-info-label">联系电话：</text>
            <text class="modal-info-val phone-val">{{activeBooking.patientPhone}} 📞</text>
          </view>

          <view class="modal-info-item" wx:if="{{activeBooking.remarks}}">
            <text class="modal-info-label">备注要求：</text>
            <text class="modal-info-val">{{activeBooking.remarks}}</text>
          </view>
        </view>

        <!-- 取消原因 (若已取消) -->
        <view class="cancel-reason-box" style="margin: 10rpx 0 0 0;" wx:if="{{activeBooking.status === 'cancelled' && activeBooking.cancelReason}}">
          <text class="reason-title">取消原因：</text>
          <text class="reason-content">{{activeBooking.cancelReason}}</text>
        </view>
      </view>

      <view class="modal-footer">
        <button class="btn btn-primary close-modal-btn" bindtap="closeDetailModal">我知道了</button>
      </view>

    </view>
  </view>

</view>
