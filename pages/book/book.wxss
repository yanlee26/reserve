/* pages/book/book.wxss */

.page-book {
  padding: 24rpx 24rpx 180rpx 24rpx;
  background-color: var(--bg-main);
  box-sizing: border-box;
  min-height: 100vh;
}

/* 表单板块 */
.form-section {
  background-color: #ffffff;
  border-radius: var(--radius-lg);
  padding: 30rpx;
  margin-bottom: 28rpx;
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--border-color);
}

.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  position: relative;
  padding-left: 16rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 6rpx;
  bottom: 6rpx;
  width: 6rpx;
  background-color: var(--primary);
  border-radius: var(--radius-full);
}

.section-sub {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 600;
}

/* 日期滑块 */
.date-scroll {
  white-space: nowrap;
  width: 100%;
}

.date-pill {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  background-color: var(--bg-main);
  border-radius: var(--radius-md);
  margin-right: 16rpx;
  transition: all 0.2s;
  border: 2rpx solid transparent;
}

.date-pill:active {
  transform: scale(0.95);
}

.date-pill.active {
  background-color: var(--primary-light);
  color: var(--primary);
  border-color: var(--primary);
}

.day-name {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 8rpx;
}

.date-pill.active .day-name {
  color: var(--primary);
}

.day-date {
  font-size: 26rpx;
  font-weight: 700;
}

/* 时间段网格 */
.slot-header {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-sub);
  margin: 12rpx 0 20rpx 0;
}

.time-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.time-cell {
  background-color: var(--bg-main);
  border-radius: var(--radius-md);
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  border: 2rpx solid transparent;
}

.time-cell:active {
  transform: scale(0.95);
}

.time-cell.active {
  background-color: var(--primary-light);
  border-color: var(--primary);
}

.time-cell.active .time-val {
  color: var(--primary);
  font-weight: 700;
}

.time-val {
  font-size: 26rpx;
  color: var(--text-main);
  font-weight: 500;
}

.time-cell.disabled {
  background-color: #f1f5f9;
  border-color: transparent;
  pointer-events: none;
}

.time-cell.disabled .time-val {
  color: #cbd5e1;
}

/* 顾客输入表单 */
.input-group {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--border-color);
}

.input-group .label {
  width: 140rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-sub);
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-main);
}

.form-textarea {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-main);
  height: 100rpx;
  padding-top: 4rpx;
}

.input-group.textarea-group {
  align-items: flex-start;
}

.input-group.textarea-group .label {
  padding-top: 4rpx;
}

.placeholder {
  color: var(--text-light);
}

/* 底部操作栏 */
.book-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 140rpx;
  background-color: #ffffff;
  border-top: 2rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  box-sizing: border-box;
  z-index: 100;
  box-shadow: 0 -4px 10px -2px rgba(15, 23, 42, 0.05);
}

.footer-summary {
  display: flex;
  flex-direction: column;
}

.time-label {
  font-size: 20rpx;
  color: var(--text-muted);
  margin-bottom: 4rpx;
}

.time-summary {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--primary);
}

.time-summary.placeholder {
  color: var(--text-light);
  font-weight: 500;
  font-size: 26rpx;
}

.footer-submit-btn {
  width: 240rpx !important;
  height: 88rpx;
  border-radius: var(--radius-full);
}

/* 备注要求样式 */
.remark-section {
  padding: 24rpx 0 10rpx 0;
}

.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-sub);
  display: block;
  margin-bottom: 20rpx;
}

.remark-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.remark-pill {
  padding: 12rpx 28rpx;
  font-size: 24rpx;
  color: var(--text-sub);
  background-color: var(--bg-main);
  border-radius: var(--radius-full);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.remark-pill:active {
  transform: scale(0.95);
}

.remark-pill.active {
  color: var(--primary);
  background-color: var(--primary-light);
  border-color: var(--primary);
  font-weight: 600;
}

.custom-remark-container {
  margin-top: 20rpx;
  background-color: var(--bg-main);
  border-radius: var(--radius-md);
  padding: 20rpx;
  border: 2rpx solid var(--border-color);
}

.custom-textarea {
  width: 100%;
  height: 120rpx;
  font-size: 26rpx;
  color: var(--text-main);
  box-sizing: border-box;
}
